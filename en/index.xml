    <item>
      <title>Guestbook</title>
      <link>https://fairchild26.github.io/en/message/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      
      <guid>https://fairchild26.github.io/en/message/</guid>
      <description>&lt;p&gt;Say it here 👉︎ 👉︎&lt;/p&gt;&#xA;&#xA;&#xA;&#xA;&#xA;&lt;div class=&#34;choice-box&#34; data-id=&#34;62710984135&#34; data-mode=&#34;single&#34;&gt;&#xA;  &lt;h2 class=&#34;choice-title&#34;&gt;🌱 What should one pursue most in life?&lt;/h2&gt;&#xA;&#xA;  &lt;div class=&#34;choice-options&#34;&gt;&#xA;    &#xA;      &#xA;        &lt;label class=&#34;choice-item&#34;&gt;&#xA;          &#xA;            &lt;input type=&#34;radio&#34; name=&#34;choice_62710984135&#34; value=&#34;💧 Inner peace&#34;&gt;&#xA;          &#xA;          &lt;span class=&#34;choice-text&#34;&gt;💧 Inner peace&lt;/span&gt;&#xA;        &lt;/label&gt;&#xA;      &#xA;    &#xA;      &#xA;        &lt;label class=&#34;choice-item&#34;&gt;&#xA;          &#xA;            &lt;input type=&#34;radio&#34; name=&#34;choice_62710984135&#34; value=&#34;🚀 Career success&#34;&gt;&#xA;          &#xA;          &lt;span class=&#34;choice-text&#34;&gt;🚀 Career success&lt;/span&gt;&#xA;        &lt;/label&gt;&#xA;      &#xA;    &#xA;      &#xA;        &lt;label class=&#34;choice-item&#34;&gt;&#xA;          &#xA;            &lt;input type=&#34;radio&#34; name=&#34;choice_62710984135&#34; value=&#34;🏠 Warmth of family&#34;&gt;&#xA;          &#xA;          &lt;span class=&#34;choice-text&#34;&gt;🏠 Warmth of family&lt;/span&gt;&#xA;        &lt;/label&gt;&#xA;      &#xA;    &#xA;      &#xA;        &lt;label class=&#34;choice-item&#34;&gt;&#xA;          &#xA;            &lt;input type=&#34;radio&#34; name=&#34;choice_62710984135&#34; value=&#34;🌍 Freedom of exploration&#34;&gt;&#xA;          &#xA;          &lt;span class=&#34;choice-text&#34;&gt;🌍 Freedom of exploration&lt;/span&gt;&#xA;        &lt;/label&gt;&#xA;      &#xA;    &#xA;      &#xA;    &#xA;      &#xA;    &#xA;      &#xA;    &#xA;      &#xA;    &#xA;  &lt;/div&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;style&gt;&#xA;.choice-box{&#xA;  max-width:720px;&#xA;  margin:2rem auto;&#xA;  padding:1.5rem;&#xA;  border-radius:1rem;&#xA;  border:1px solid #21262d;&#xA;  background:var(--choice-bg, transparent);&#xA;}&#xA;.dark .choice-box{ border-color:#30363d; }&#xA;&#xA;.choice-title{&#xA;  font-size:1.5rem;&#xA;  font-weight:700;&#xA;  text-align:center;&#xA;  margin-bottom:1.2rem;&#xA;}&#xA;&#xA;.choice-options{&#xA;  display:grid;&#xA;  grid-template-columns:1fr;&#xA;  gap:.75rem;&#xA;}&#xA;&#xA;.choice-item{&#xA;  display:flex;&#xA;  align-items:center;&#xA;  gap:.75rem;&#xA;  padding:.8rem 1rem;&#xA;  border-radius:.75rem;&#xA;  border:1px solid #21262d;&#xA;  cursor:pointer;&#xA;  transition:all .2s ease;&#xA;  user-select:none;&#xA;}&#xA;.dark .choice-item{ border-color:#30363d; }&#xA;&#xA;.choice-item:hover{&#xA;  transform:translateY(-1px);&#xA;  box-shadow:0 6px 16px rgba(0,0,0,.06);&#xA;}&#xA;&#xA;.choice-item input{ display:none; }&#xA;&#xA;.choice-item:has(input:checked){&#xA;  border-color:#22c55e;&#xA;  background:rgba(34,197,94,0.08);&#xA;}&#xA;&#xA;.choice-item input:checked + .choice-text{&#xA;  font-weight:600;&#xA;  color:#16a34a;&#xA;}&#xA;&lt;/style&gt;&#xA;&#xA;&lt;script&gt;&#xA;(function(){&#xA;  const box = document.querySelector(&#39;.choice-box[data-id=&#34;62710984135&#34;]&#39;);&#xA;  if(!box) return;&#xA;&#xA;  const mode = box.dataset.mode;&#xA;  const inputs = box.querySelectorAll(&#39;input&#39;);&#xA;  const KEY = &#34;multi_choice_62710984135&#34;;&#xA;&#xA;  &#xA;  const saved = JSON.parse(localStorage.getItem(KEY) || &#34;[]&#34;);&#xA;&#xA;  inputs.forEach(i=&gt;{&#xA;    if(saved.includes(i.value)){&#xA;      i.checked = true;&#xA;    }&#xA;  });&#xA;&#xA;  &#xA;  inputs.forEach(i=&gt;{&#xA;    i.addEventListener(&#34;change&#34;, ()=&gt;{&#xA;      let selected = [];&#xA;&#xA;      if(mode === &#34;single&#34;){&#xA;        selected = [i.value];&#xA;        inputs.forEach(x=&gt;{&#xA;          if(x !== i) x.checked = false;&#xA;        });&#xA;      }else{&#xA;        selected = [...inputs].filter(x=&gt;x.checked).map(x=&gt;x.value);&#xA;      }&#xA;&#xA;      localStorage.setItem(KEY, JSON.stringify(selected));&#xA;    });&#xA;  });&#xA;})();&#xA;&lt;/script&gt;</description>
      
    </item>
    
