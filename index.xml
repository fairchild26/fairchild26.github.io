    <item>
      <title>国内外 Qt 资源</title>
      <link>https://fairchild26.github.io/cpp/qt-res/</link>
      <pubDate>Sun, 05 Apr 2026 00:00:00 +0000</pubDate>
      
      <guid>https://fairchild26.github.io/cpp/qt-res/</guid>
      <description>&lt;h2 class=&#34;relative group&#34;&gt;一、国外 Qt 相关网站&#xD;&#xA;    &lt;div id=&#34;一国外-qt-相关网站&#34; class=&#34;anchor&#34;&gt;&lt;/div&gt;&#xD;&#xA;    &#xD;&#xA;    &lt;span&#xD;&#xA;        class=&#34;absolute top-0 w-6 transition-opacity opacity-0 -start-6 not-prose group-hover:opacity-100 select-none&#34;&gt;&#xD;&#xA;        &lt;a class=&#34;text-primary-300 dark:text-neutral-700 !no-underline&#34; href=&#34;#%e4%b8%80%e5%9b%bd%e5%a4%96-qt-%e7%9b%b8%e5%85%b3%e7%bd%91%e7%ab%99&#34; aria-label=&#34;锚点&#34;&gt;#&lt;/a&gt;&#xD;&#xA;    &lt;/span&gt;&#xD;&#xA;    &#xD;&#xA;&lt;/h2&gt;&#xD;&#xA;&#xD;&#xA;&lt;h3 class=&#34;relative group&#34;&gt;1. 官方资源&#xD;&#xA;    &lt;div id=&#34;1-官方资源&#34; class=&#34;anchor&#34;&gt;&lt;/div&gt;&#xD;&#xA;    &#xD;&#xA;    &lt;span&#xD;&#xA;        class=&#34;absolute top-0 w-6 transition-opacity opacity-0 -start-6 not-prose group-hover:opacity-100 select-none&#34;&gt;&#xD;&#xA;        &lt;a class=&#34;text-primary-300 dark:text-neutral-700 !no-underline&#34; href=&#34;#1-%e5%ae%98%e6%96%b9%e8%b5%84%e6%ba%90&#34; aria-label=&#34;锚点&#34;&gt;#&lt;/a&gt;&#xD;&#xA;    &lt;/span&gt;&#xD;&#xA;    &#xD;&#xA;&lt;/h3&gt;&#xD;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;&lt;strong&gt;Qt 官网&lt;/strong&gt;： &lt;a href=&#34;https://www.qt.io/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;https://www.qt.io/&lt;/a&gt;&lt;br&gt;&#xA;Qt 的官方网站，提供最新版本下载、资讯和在线帮助文档。&lt;/li&gt;&#xA;&lt;li&gt;&lt;strong&gt;Qt 官方文档&lt;/strong&gt;： &lt;a href=&#34;https://doc.qt.io/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;https://doc.qt.io/&lt;/a&gt;&lt;br&gt;&#xA;核心学习资源，涵盖 API 参考、教程和示例代码。&lt;/li&gt;&#xA;&lt;li&gt;&lt;strong&gt;Qt 下载页面&lt;/strong&gt;： &lt;a href=&#34;http://download.qt.io/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;http://download.qt.io/&lt;/a&gt;&lt;br&gt;&#xA;所有安装程序、源码和离线包的官方地址。&lt;/li&gt;&#xA;&lt;li&gt;&lt;strong&gt;Qt Wiki&lt;/strong&gt;： &lt;a href=&#34;http://wiki.qt.io/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;http://wiki.qt.io/&lt;/a&gt;&lt;br&gt;&#xA;社区维护的知识库，包含大量文章和教程。&lt;/li&gt;&#xA;&lt;li&gt;&lt;strong&gt;Qt Academy&lt;/strong&gt;： &lt;a href=&#34;https://academy.qt.io/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;https://academy.qt.io/&lt;/a&gt;&lt;br&gt;&#xA;官方在线课程平台，提供系统化培训。&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xD;&#xA;&lt;h3 class=&#34;relative group&#34;&gt;2. 社区、论坛与问答&#xD;&#xA;    &lt;div id=&#34;2-社区论坛与问答&#34; class=&#34;anchor&#34;&gt;&lt;/div&gt;&#xD;&#xA;    &#xD;&#xA;    &lt;span&#xD;&#xA;        class=&#34;absolute top-0 w-6 transition-opacity opacity-0 -start-6 not-prose group-hover:opacity-100 select-none&#34;&gt;&#xD;&#xA;        &lt;a class=&#34;text-primary-300 dark:text-neutral-700 !no-underline&#34; href=&#34;#2-%e7%a4%be%e5%8c%ba%e8%ae%ba%e5%9d%9b%e4%b8%8e%e9%97%ae%e7%ad%94&#34; aria-label=&#34;锚点&#34;&gt;#&lt;/a&gt;&#xD;&#xA;    &lt;/span&gt;&#xD;&#xA;    &#xD;&#xA;&lt;/h3&gt;&#xD;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;&lt;strong&gt;Qt 官方论坛&lt;/strong&gt;： &lt;a href=&#34;https://forum.qt.io/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;https://forum.qt.io/&lt;/a&gt;&lt;br&gt;&#xA;官方讨论平台，可提问、解答或分享经验。&lt;/li&gt;&#xA;&lt;li&gt;&lt;strong&gt;Qt Centre&lt;/strong&gt;： &lt;a href=&#34;https://www.qtcentre.org/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;https://www.qtcentre.org/&lt;/a&gt;&lt;br&gt;&#xA;老牌 Qt 社区，提供论坛、文档、博客。&lt;/li&gt;&#xA;&lt;li&gt;&lt;strong&gt;Stack Overflow&lt;/strong&gt;： &lt;a href=&#34;https://stackoverflow.com/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;https://stackoverflow.com/&lt;/a&gt;&lt;br&gt;&#xA;全球最大技术问答社区，搜索时带上 Qt 版本（如 Qt6）。&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xD;&#xA;&lt;h3 class=&#34;relative group&#34;&gt;3. 博客与技术分享&#xD;&#xA;    &lt;div id=&#34;3-博客与技术分享&#34; class=&#34;anchor&#34;&gt;&lt;/div&gt;&#xD;&#xA;    &#xD;&#xA;    &lt;span&#xD;&#xA;        class=&#34;absolute top-0 w-6 transition-opacity opacity-0 -start-6 not-prose group-hover:opacity-100 select-none&#34;&gt;&#xD;&#xA;        &lt;a class=&#34;text-primary-300 dark:text-neutral-700 !no-underline&#34; href=&#34;#3-%e5%8d%9a%e5%ae%a2%e4%b8%8e%e6%8a%80%e6%9c%af%e5%88%86%e4%ba%ab&#34; aria-label=&#34;锚点&#34;&gt;#&lt;/a&gt;&#xD;&#xA;    &lt;/span&gt;&#xD;&#xA;    &#xD;&#xA;&lt;/h3&gt;&#xD;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;&lt;strong&gt;Planet Qt&lt;/strong&gt;： &lt;a href=&#34;http://planet.qt.io/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;http://planet.qt.io/&lt;/a&gt;&lt;br&gt;&#xA;全球 Qt 开发者博客聚合站点。&lt;/li&gt;&#xA;&lt;li&gt;&lt;strong&gt;KDAB 博客&lt;/strong&gt;： &lt;a href=&#34;https://www.kdab.com/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;https://www.kdab.com/&lt;/a&gt;&lt;br&gt;&#xA;KDAB 公司提供的高质量 Qt、C++ 技术文章和视频。&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xD;&#xA;&lt;h3 class=&#34;relative group&#34;&gt;4. GitHub 与开源资源&#xD;&#xA;    &lt;div id=&#34;4-github-与开源资源&#34; class=&#34;anchor&#34;&gt;&lt;/div&gt;&#xD;&#xA;    &#xD;&#xA;    &lt;span&#xD;&#xA;        class=&#34;absolute top-0 w-6 transition-opacity opacity-0 -start-6 not-prose group-hover:opacity-100 select-none&#34;&gt;&#xD;&#xA;        &lt;a class=&#34;text-primary-300 dark:text-neutral-700 !no-underline&#34; href=&#34;#4-github-%e4%b8%8e%e5%bc%80%e6%ba%90%e8%b5%84%e6%ba%90&#34; aria-label=&#34;锚点&#34;&gt;#&lt;/a&gt;&#xD;&#xA;    &lt;/span&gt;&#xD;&#xA;    &#xD;&#xA;&lt;/h3&gt;&#xD;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;&lt;strong&gt;Qt Project GitHub&lt;/strong&gt;： &lt;a href=&#34;https://github.com/qtproject/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;https://github.com/qtproject/&lt;/a&gt;&lt;br&gt;&#xA;Qt 官方 GitHub 组织，包含源码、示例和工具。&lt;/li&gt;&#xA;&lt;li&gt;&lt;strong&gt;Awesome Qt Learning&lt;/strong&gt;： &lt;a href=&#34;https://github.com/0voice/Awesome_Qt_Learning/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;https://github.com/0voice/Awesome_Qt_Learning/&lt;/a&gt;&lt;br&gt;&#xA;高星级 Qt 学习资源整合仓库，涵盖基础到实战。&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xD;&#xA;&lt;h3 class=&#34;relative group&#34;&gt;5. 在线课程平台&#xD;&#xA;    &lt;div id=&#34;5-在线课程平台&#34; class=&#34;anchor&#34;&gt;&lt;/div&gt;&#xD;&#xA;    &#xD;&#xA;    &lt;span&#xD;&#xA;        class=&#34;absolute top-0 w-6 transition-opacity opacity-0 -start-6 not-prose group-hover:opacity-100 select-none&#34;&gt;&#xD;&#xA;        &lt;a class=&#34;text-primary-300 dark:text-neutral-700 !no-underline&#34; href=&#34;#5-%e5%9c%a8%e7%ba%bf%e8%af%be%e7%a8%8b%e5%b9%b3%e5%8f%b0&#34; aria-label=&#34;锚点&#34;&gt;#&lt;/a&gt;&#xD;&#xA;    &lt;/span&gt;&#xD;&#xA;    &#xD;&#xA;&lt;/h3&gt;&#xD;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;&lt;strong&gt;Udemy&lt;/strong&gt;： &lt;a href=&#34;https://www.udemy.com/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;https://www.udemy.com/&lt;/a&gt;&lt;br&gt;&#xA;提供《Qt6 Core for Beginners with C++》等实战课程。&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xD;&#xA;&lt;h2 class=&#34;relative group&#34;&gt;二、国内 Qt 相关网站&#xD;&#xA;    &lt;div id=&#34;二国内-qt-相关网站&#34; class=&#34;anchor&#34;&gt;&lt;/div&gt;&#xD;&#xA;    &#xD;&#xA;    &lt;span&#xD;&#xA;        class=&#34;absolute top-0 w-6 transition-opacity opacity-0 -start-6 not-prose group-hover:opacity-100 select-none&#34;&gt;&#xD;&#xA;        &lt;a class=&#34;text-primary-300 dark:text-neutral-700 !no-underline&#34; href=&#34;#%e4%ba%8c%e5%9b%bd%e5%86%85-qt-%e7%9b%b8%e5%85%b3%e7%bd%91%e7%ab%99&#34; aria-label=&#34;锚点&#34;&gt;#&lt;/a&gt;&#xD;&#xA;    &lt;/span&gt;&#xD;&#xA;    &#xD;&#xA;&lt;/h2&gt;&#xD;&#xA;&#xD;&#xA;&lt;h3 class=&#34;relative group&#34;&gt;1. 中文社区、论坛与问答&#xD;&#xA;    &lt;div id=&#34;1-中文社区论坛与问答&#34; class=&#34;anchor&#34;&gt;&lt;/div&gt;&#xD;&#xA;    &#xD;&#xA;    &lt;span&#xD;&#xA;        class=&#34;absolute top-0 w-6 transition-opacity opacity-0 -start-6 not-prose group-hover:opacity-100 select-none&#34;&gt;&#xD;&#xA;        &lt;a class=&#34;text-primary-300 dark:text-neutral-700 !no-underline&#34; href=&#34;#1-%e4%b8%ad%e6%96%87%e7%a4%be%e5%8c%ba%e8%ae%ba%e5%9d%9b%e4%b8%8e%e9%97%ae%e7%ad%94&#34; aria-label=&#34;锚点&#34;&gt;#&lt;/a&gt;&#xD;&#xA;    &lt;/span&gt;&#xD;&#xA;    &#xD;&#xA;&lt;/h3&gt;&#xD;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;&lt;strong&gt;QTCN 开发网&lt;/strong&gt;： &lt;a href=&#34;http://www.qtcn.org/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;http://www.qtcn.org/&lt;/a&gt;&lt;br&gt;&#xA;国内最早、最活跃的 Qt 中文社区。&lt;/li&gt;&#xA;&lt;li&gt;&lt;strong&gt;Qter 开源社区&lt;/strong&gt;： &lt;a href=&#34;http://www.qter.org/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;http://www.qter.org/&lt;/a&gt;&lt;br&gt;&#xA;专注 Qt 普及，提供原创教程和开源项目，适合初学者。&lt;/li&gt;&#xA;&lt;li&gt;&lt;strong&gt;CSDN Qt 论坛&lt;/strong&gt;： &lt;a href=&#34;https://bbs.csdn.net/forums/Qt/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;https://bbs.csdn.net/forums/Qt/&lt;/a&gt;&lt;br&gt;&#xA;CSDN 平台下的 Qt 技术讨论区。&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xD;&#xA;&lt;h3 class=&#34;relative group&#34;&gt;2. 博客与技术专栏&#xD;&#xA;    &lt;div id=&#34;2-博客与技术专栏&#34; class=&#34;anchor&#34;&gt;&lt;/div&gt;&#xD;&#xA;    &#xD;&#xA;    &lt;span&#xD;&#xA;        class=&#34;absolute top-0 w-6 transition-opacity opacity-0 -start-6 not-prose group-hover:opacity-100 select-none&#34;&gt;&#xD;&#xA;        &lt;a class=&#34;text-primary-300 dark:text-neutral-700 !no-underline&#34; href=&#34;#2-%e5%8d%9a%e5%ae%a2%e4%b8%8e%e6%8a%80%e6%9c%af%e4%b8%93%e6%a0%8f&#34; aria-label=&#34;锚点&#34;&gt;#&lt;/a&gt;&#xD;&#xA;    &lt;/span&gt;&#xD;&#xA;    &#xD;&#xA;&lt;/h3&gt;&#xD;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;&lt;strong&gt;一去丶二三里&lt;/strong&gt;： &lt;a href=&#34;https://waleon.blog.csdn.net/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;https://waleon.blog.csdn.net/&lt;/a&gt;&lt;br&gt;&#xA;CSDN 知名 Qt 博主，内容涉及开发技巧和源码分析。&lt;/li&gt;&#xA;&lt;li&gt;&lt;strong&gt;foruok&lt;/strong&gt;： &lt;a href=&#34;http://blog.csdn.net/foruok/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;http://blog.csdn.net/foruok/&lt;/a&gt;&lt;br&gt;&#xA;聚焦程序员职业规划与 Qt 技术文章。&lt;/li&gt;&#xA;&lt;li&gt;&lt;strong&gt;知乎专栏《Qt 进阶之路》&lt;/strong&gt;： &lt;a href=&#34;https://zhuanlan.zhihu.com/p/345452320/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;https://zhuanlan.zhihu.com/p/345452320/&lt;/a&gt;&lt;br&gt;&#xA;深入讲解 Qt 实用技能、QML 组件化和特效。&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xD;&#xA;&lt;h3 class=&#34;relative group&#34;&gt;3. 综合技术社区&#xD;&#xA;    &lt;div id=&#34;3-综合技术社区&#34; class=&#34;anchor&#34;&gt;&lt;/div&gt;&#xD;&#xA;    &#xD;&#xA;    &lt;span&#xD;&#xA;        class=&#34;absolute top-0 w-6 transition-opacity opacity-0 -start-6 not-prose group-hover:opacity-100 select-none&#34;&gt;&#xD;&#xA;        &lt;a class=&#34;text-primary-300 dark:text-neutral-700 !no-underline&#34; href=&#34;#3-%e7%bb%bc%e5%90%88%e6%8a%80%e6%9c%af%e7%a4%be%e5%8c%ba&#34; aria-label=&#34;锚点&#34;&gt;#&lt;/a&gt;&#xD;&#xA;    &lt;/span&gt;&#xD;&#xA;    &#xD;&#xA;&lt;/h3&gt;&#xD;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;&lt;strong&gt;CSDN&lt;/strong&gt;： &lt;a href=&#34;https://www.csdn.net/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;https://www.csdn.net/&lt;/a&gt;&lt;br&gt;&#xA;搜索“Qt”可找到大量技术文章和解决方案。&lt;/li&gt;&#xA;&lt;li&gt;&lt;strong&gt;博客园&lt;/strong&gt;： &lt;a href=&#34;https://www.cnblogs.com/&#34;  target=&#34;_blank&#34; rel=&#34;noreferrer&#34;&gt;https://www.cnblogs.com/&lt;/a&gt;&lt;br&gt;&#xA;搜索“Qt”标签获取高质量原创文章。&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xD;&#xA;&lt;h3 class=&#34;relative group&#34;&gt;4. 书籍资源&#xD;&#xA;    &lt;div id=&#34;4-书籍资源&#34; class=&#34;anchor&#34;&gt;&lt;/div&gt;&#xD;&#xA;    &#xD;&#xA;    &lt;span&#xD;&#xA;        class=&#34;absolute top-0 w-6 transition-opacity opacity-0 -start-6 not-prose group-hover:opacity-100 select-none&#34;&gt;&#xD;&#xA;        &lt;a class=&#34;text-primary-300 dark:text-neutral-700 !no-underline&#34; href=&#34;#4-%e4%b9%a6%e7%b1%8d%e8%b5%84%e6%ba%90&#34; aria-label=&#34;锚点&#34;&gt;#&lt;/a&gt;&#xD;&#xA;    &lt;/span&gt;&#xD;&#xA;    &#xD;&#xA;&lt;/h3&gt;&#xD;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;&lt;strong&gt;《Qt Creator 快速入门》&lt;/strong&gt;（霍亚飞）—— Qt 入门经典。&lt;/li&gt;&#xA;&lt;li&gt;&lt;strong&gt;《C++ GUI Qt4 编程》&lt;/strong&gt; —— Qt 进阶权威著作。&lt;/li&gt;&#xA;&lt;li&gt;&lt;strong&gt;《Qt5 编程入门》&lt;/strong&gt; —— QML/QtQuick 方向学习书籍。&lt;/li&gt;&#xA;&lt;/ul&gt;</description>
      
    </item>
    
    <item>
      <title>Python 流程控制语句</title>
      <link>https://fairchild26.github.io/python/if/</link>
      <pubDate>Wed, 18 Mar 2026 00:00:00 +0000</pubDate>
      
      <guid>https://fairchild26.github.io/python/if/</guid>
      <description>&lt;p&gt;在 Python 中，流程控制语句用于控制程序的执行流程。常见的流程控制语句包括条件语句（如 &lt;code&gt;if&lt;/code&gt; 语句）和循环语句（如 &lt;code&gt;for&lt;/code&gt; 和 &lt;code&gt;while&lt;/code&gt; 语句）。本文将介绍这些基本的流程控制语句，并提供一些示例代码。&lt;/p&gt;</description>
      
    </item>
    
    <item>
      <title>Python 入门</title>
      <link>https://fairchild26.github.io/python/hello/</link>
      <pubDate>Tue, 17 Mar 2026 00:00:00 +0000</pubDate>
      
      <guid>https://fairchild26.github.io/python/hello/</guid>
      <description>&lt;h2 class=&#34;relative group&#34;&gt;1 输入输出&#xD;&#xA;    &lt;div id=&#34;1-输入输出&#34; class=&#34;anchor&#34;&gt;&lt;/div&gt;&#xD;&#xA;    &#xD;&#xA;    &lt;span&#xD;&#xA;        class=&#34;absolute top-0 w-6 transition-opacity opacity-0 -start-6 not-prose group-hover:opacity-100 select-none&#34;&gt;&#xD;&#xA;        &lt;a class=&#34;text-primary-300 dark:text-neutral-700 !no-underline&#34; href=&#34;#1-%e8%be%93%e5%85%a5%e8%be%93%e5%87%ba&#34; aria-label=&#34;锚点&#34;&gt;#&lt;/a&gt;&#xD;&#xA;    &lt;/span&gt;&#xD;&#xA;    &#xD;&#xA;&lt;/h2&gt;&#xD;&#xA;&lt;div class=&#34;highlight-wrapper&#34;&gt;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code class=&#34;language-py&#34; data-lang=&#34;py&#34;&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;kn&#34;&gt;import&lt;/span&gt; &lt;span class=&#34;nn&#34;&gt;os&lt;/span&gt;                                           &lt;span class=&#34;c1&#34;&gt;# 导入 操作系统接口模块&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;nb&#34;&gt;print&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;s2&#34;&gt;&amp;#34;hello world&amp;#34;&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;)&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;n&#34;&gt;price&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;=&lt;/span&gt; &lt;span class=&#34;mf&#34;&gt;9.15&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;nb&#34;&gt;print&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;s2&#34;&gt;&amp;#34;The price of the shirt is &lt;/span&gt;&lt;span class=&#34;si&#34;&gt;%.2f&lt;/span&gt;&lt;span class=&#34;s2&#34;&gt; £.&amp;#34;&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;%&lt;/span&gt; &lt;span class=&#34;n&#34;&gt;price&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;)&lt;/span&gt;  &lt;span class=&#34;c1&#34;&gt;# 格式化输出&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;nb&#34;&gt;print&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;sa&#34;&gt;f&lt;/span&gt;&lt;span class=&#34;s2&#34;&gt;&amp;#34;The price of the shirt is &lt;/span&gt;&lt;span class=&#34;si&#34;&gt;{&lt;/span&gt;&lt;span class=&#34;n&#34;&gt;price&lt;/span&gt;&lt;span class=&#34;si&#34;&gt;}&lt;/span&gt;&lt;span class=&#34;s2&#34;&gt; £.&amp;#34;&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;)&lt;/span&gt;      &lt;span class=&#34;c1&#34;&gt;# f-strings 输出&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;nb&#34;&gt;print&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;s2&#34;&gt;&amp;#34;Name: &lt;/span&gt;&lt;span class=&#34;si&#34;&gt;%s&lt;/span&gt;&lt;span class=&#34;s2&#34;&gt; &lt;/span&gt;&lt;span class=&#34;se&#34;&gt;\n&lt;/span&gt;&lt;span class=&#34;s2&#34;&gt;Score: &lt;/span&gt;&lt;span class=&#34;si&#34;&gt;%d&lt;/span&gt;&lt;span class=&#34;s2&#34;&gt;&amp;#34;&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;%&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;s2&#34;&gt;&amp;#34;Jack&amp;#34;&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;,&lt;/span&gt; &lt;span class=&#34;mi&#34;&gt;95&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;))&lt;/span&gt;         &lt;span class=&#34;c1&#34;&gt;# \n 换行&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;nb&#34;&gt;print&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;s2&#34;&gt;&amp;#34;-&amp;#34;&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;*&lt;/span&gt; &lt;span class=&#34;mi&#34;&gt;33&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;)&lt;/span&gt;                                     &lt;span class=&#34;c1&#34;&gt;# 连续打印&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;n&#34;&gt;password&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;=&lt;/span&gt; &lt;span class=&#34;nb&#34;&gt;input&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;s2&#34;&gt;&amp;#34;Enter password &amp;#34;&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;)&lt;/span&gt;                 &lt;span class=&#34;c1&#34;&gt;# 打印提示信息并获取数据&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;nb&#34;&gt;print&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;nb&#34;&gt;type&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;n&#34;&gt;password&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;))&lt;/span&gt;                               &lt;span class=&#34;c1&#34;&gt;# 默认字符串格式&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&#xD;&#xA;&#xD;&#xA;&lt;h2 class=&#34;relative group&#34;&gt;2 注释&#xD;&#xA;    &lt;div id=&#34;2-注释&#34; class=&#34;anchor&#34;&gt;&lt;/div&gt;&#xD;&#xA;    &#xD;&#xA;    &lt;span&#xD;&#xA;        class=&#34;absolute top-0 w-6 transition-opacity opacity-0 -start-6 not-prose group-hover:opacity-100 select-none&#34;&gt;&#xD;&#xA;        &lt;a class=&#34;text-primary-300 dark:text-neutral-700 !no-underline&#34; href=&#34;#2-%e6%b3%a8%e9%87%8a&#34; aria-label=&#34;锚点&#34;&gt;#&lt;/a&gt;&#xD;&#xA;    &lt;/span&gt;&#xD;&#xA;    &#xD;&#xA;&lt;/h2&gt;&#xD;&#xA;&lt;div class=&#34;highlight-wrapper&#34;&gt;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code class=&#34;language-py&#34; data-lang=&#34;py&#34;&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;c1&#34;&gt;# 单行注释&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;s2&#34;&gt;&amp;#34;&amp;#34;&amp;#34;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;s2&#34;&gt;双引号&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;s2&#34;&gt;多行注释&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;s2&#34;&gt;&amp;#34;&amp;#34;&amp;#34;&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;s1&#34;&gt;&amp;#39;&amp;#39;&amp;#39;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;s1&#34;&gt;单引号&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;s1&#34;&gt;多行注释&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;s1&#34;&gt;&amp;#39;&amp;#39;&amp;#39;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&#xD;&#xA;&#xD;&#xA;&lt;h2 class=&#34;relative group&#34;&gt;3 变量&#xD;&#xA;    &lt;div id=&#34;3-变量&#34; class=&#34;anchor&#34;&gt;&lt;/div&gt;&#xD;&#xA;    &#xD;&#xA;    &lt;span&#xD;&#xA;        class=&#34;absolute top-0 w-6 transition-opacity opacity-0 -start-6 not-prose group-hover:opacity-100 select-none&#34;&gt;&#xD;&#xA;        &lt;a class=&#34;text-primary-300 dark:text-neutral-700 !no-underline&#34; href=&#34;#3-%e5%8f%98%e9%87%8f&#34; aria-label=&#34;锚点&#34;&gt;#&lt;/a&gt;&#xD;&#xA;    &lt;/span&gt;&#xD;&#xA;    &#xD;&#xA;&lt;/h2&gt;&#xD;&#xA;&lt;div class=&#34;highlight-wrapper&#34;&gt;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code class=&#34;language-py&#34; data-lang=&#34;py&#34;&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;n&#34;&gt;a&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;=&lt;/span&gt; &lt;span class=&#34;mi&#34;&gt;2&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;n&#34;&gt;b&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;=&lt;/span&gt; &lt;span class=&#34;mi&#34;&gt;3&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;n&#34;&gt;c&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;=&lt;/span&gt; &lt;span class=&#34;n&#34;&gt;a&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;+&lt;/span&gt; &lt;span class=&#34;n&#34;&gt;b&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;nb&#34;&gt;print&lt;/span&gt; &lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;s2&#34;&gt;&amp;#34;a + b =&amp;#34;&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;,&lt;/span&gt; &lt;span class=&#34;n&#34;&gt;c&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;)&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;nb&#34;&gt;print&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;nb&#34;&gt;type&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;n&#34;&gt;c&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;))&lt;/span&gt;      &lt;span class=&#34;c1&#34;&gt;# int&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;nb&#34;&gt;print&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;nb&#34;&gt;type&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;mf&#34;&gt;3.14&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;))&lt;/span&gt;   &lt;span class=&#34;c1&#34;&gt;# float&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;n&#34;&gt;a&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;=&lt;/span&gt; &lt;span class=&#34;p&#34;&gt;[&lt;/span&gt;&lt;span class=&#34;mi&#34;&gt;9&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;,&lt;/span&gt; &lt;span class=&#34;mi&#34;&gt;5&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;,&lt;/span&gt; &lt;span class=&#34;mi&#34;&gt;2&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;,&lt;/span&gt; &lt;span class=&#34;mi&#34;&gt;7&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;]&lt;/span&gt;    &lt;span class=&#34;c1&#34;&gt;# list&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;n&#34;&gt;b&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;=&lt;/span&gt; &lt;span class=&#34;s2&#34;&gt;&amp;#34;12315&amp;#34;&lt;/span&gt;         &lt;span class=&#34;c1&#34;&gt;# str&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;nb&#34;&gt;print&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;nb&#34;&gt;type&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;n&#34;&gt;a&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;),&lt;/span&gt; &lt;span class=&#34;nb&#34;&gt;type&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;n&#34;&gt;b&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;))&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;n&#34;&gt;a&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;=&lt;/span&gt; &lt;span class=&#34;nb&#34;&gt;str&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;n&#34;&gt;a&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;)&lt;/span&gt;          &lt;span class=&#34;c1&#34;&gt;# 类型转换&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;nb&#34;&gt;print&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;nb&#34;&gt;type&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;n&#34;&gt;a&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;))&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&#xD;&#xA;&#xD;&#xA;&lt;h2 class=&#34;relative group&#34;&gt;4 标识符&#xD;&#xA;    &lt;div id=&#34;4-标识符&#34; class=&#34;anchor&#34;&gt;&lt;/div&gt;&#xD;&#xA;    &#xD;&#xA;    &lt;span&#xD;&#xA;        class=&#34;absolute top-0 w-6 transition-opacity opacity-0 -start-6 not-prose group-hover:opacity-100 select-none&#34;&gt;&#xD;&#xA;        &lt;a class=&#34;text-primary-300 dark:text-neutral-700 !no-underline&#34; href=&#34;#4-%e6%a0%87%e8%af%86%e7%ac%a6&#34; aria-label=&#34;锚点&#34;&gt;#&lt;/a&gt;&#xD;&#xA;    &lt;/span&gt;&#xD;&#xA;    &#xD;&#xA;&lt;/h2&gt;&#xD;&#xA;&lt;ol&gt;&#xA;&lt;li&gt;见名知意&lt;/li&gt;&#xA;&lt;li&gt;由字母、数字和下划线组成，且数字不能作为开头&lt;/li&gt;&#xA;&lt;li&gt;大小写敏感&lt;/li&gt;&#xA;&lt;li&gt;不能和关键字重复&lt;/li&gt;&#xA;&lt;/ol&gt;&#xA;&lt;div class=&#34;highlight-wrapper&#34;&gt;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code class=&#34;language-py&#34; data-lang=&#34;py&#34;&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;n&#34;&gt;myBook&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;=&lt;/span&gt; &lt;span class=&#34;s2&#34;&gt;&amp;#34;围城&amp;#34;&lt;/span&gt; &lt;span class=&#34;c1&#34;&gt;# 小驼峰命名法&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;n&#34;&gt;WiFi&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;=&lt;/span&gt; &lt;span class=&#34;mi&#34;&gt;12345678&lt;/span&gt; &lt;span class=&#34;c1&#34;&gt;# 大驼峰命名法&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;n&#34;&gt;std_id&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;=&lt;/span&gt; &lt;span class=&#34;mi&#34;&gt;201009&lt;/span&gt; &lt;span class=&#34;c1&#34;&gt;# 下划线命名法&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&#xD;&#xA;&#xD;&#xA;&lt;h2 class=&#34;relative group&#34;&gt;5 运算符&#xD;&#xA;    &lt;div id=&#34;5-运算符&#34; class=&#34;anchor&#34;&gt;&lt;/div&gt;&#xD;&#xA;    &#xD;&#xA;    &lt;span&#xD;&#xA;        class=&#34;absolute top-0 w-6 transition-opacity opacity-0 -start-6 not-prose group-hover:opacity-100 select-none&#34;&gt;&#xD;&#xA;        &lt;a class=&#34;text-primary-300 dark:text-neutral-700 !no-underline&#34; href=&#34;#5-%e8%bf%90%e7%ae%97%e7%ac%a6&#34; aria-label=&#34;锚点&#34;&gt;#&lt;/a&gt;&#xD;&#xA;    &lt;/span&gt;&#xD;&#xA;    &#xD;&#xA;&lt;/h2&gt;&#xD;&#xA;&lt;p&gt;加减乘除 &lt;code&gt;+&lt;/code&gt; &lt;code&gt;-&lt;/code&gt; &lt;code&gt;*&lt;/code&gt; &lt;code&gt;/&lt;/code&gt;&lt;br&gt;&#xA;取整除 &lt;code&gt;//&lt;/code&gt; 取余 &lt;code&gt;%&lt;/code&gt; 幂 &lt;code&gt;**&lt;/code&gt;（优先级最高）&lt;br&gt;&#xA;比较运算符 &lt;code&gt;!=&lt;/code&gt; &lt;code&gt;==&lt;/code&gt;&lt;br&gt;&#xA;逻辑运算符 &lt;code&gt;and&lt;/code&gt; &lt;code&gt;or&lt;/code&gt; &lt;code&gt;not&lt;/code&gt;&lt;br&gt;&#xA;赋值运算符 &lt;code&gt;=&lt;/code&gt;&lt;br&gt;&#xA;复合运算符 &lt;code&gt;+=&lt;/code&gt; &lt;code&gt;//=&lt;/code&gt;&lt;/p&gt;</description>
      
    </item>
    
